# Open WebUI host port
OPEN_WEBUI_PORT=3000

# MCP bridge host port
MCP_BRIDGE_PORT=4000

# Ollama endpoint reachable from containers
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Disable auth for local-only demos (set True for auth)
WEBUI_AUTH=False

# MCP bridge runtime settings
MCP_TASK_STORAGE=/data/tasks.json
MCP_DOCKER_INSPECTION=true
WORKER_PREFIX=dockweave-worker-
MCP_MAX_LOG_BYTES=120000
MCP_MAX_DIFF_BYTES=200000

# Optional credentials passed into worker containers.
# Set only the keys you need; keep .env out of version control.
GITHUB_TOKEN=
GITLAB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
